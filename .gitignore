# --- Claves y secretos (NUNCA subir) ---
.env
.env.*
*.key
secrets.*
api_key*
*_apikey*

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
# Temporales filtrados por escrituras atómicas (p.ej. model.py.tmp.1234.abcd)
*.py.tmp.*
*.tmp

# --- Archivos propios de Presto (no son del proyecto, suelen estar bloqueados) ---
*.pzh
*.bak

# --- Excel (validación generada y datos de obra reales) ---
*.xlsx

# --- Config local de editores/herramientas ---
.obsidian/
.claude/

# --- Datos de obra reales (no compartir presupuestos de clientes) ---
# Se permite el ejemplo de demostración; el resto de .bc3 se ignora.
*.bc3
!ejemplo_son_font.bc3
# Archivos de prueba para los tests de regresión (necesarios en cualquier clon).
!tests/Test_SONFONT.bc3
!tests/Test_REDONDEO.bc3
!tests/Test_Alqueria.bc3

# --- Informes generados ---
informe_*.html
*.pdf

# --- Editores / SO ---
.vscode/
.idea/
.DS_Store
Thumbs.db
